# Backend Environment Variables Template
PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
# NOTE: The password here must match POSTGRES_PASSWORD in your docker-compose.yml (default: postgres)
# If you change this password after creating the local database, recreate the Docker volume
# only if you can lose local database data:
# docker compose down -v && docker compose up -d
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/notes
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT Configuration
# Secret must be at least 256 bits (32 bytes) for HMAC-SHA256. Never commit a real secret.
JWT_SECRET=CHANGE_ME_MUST_BE_AT_LEAST_256_BITS_LONG_FOR_HMAC_SHA_256
# Access token lifetime in ms (short-lived). Default 15 minutes.
JWT_EXPIRATION_MS=900000
# Refresh token lifetime in ms (long-lived). Default 7 days.
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Initial Admin Bootstrap
# Set INITIAL_ADMIN_ENABLED=true to create the first administrator on startup.
# INITIAL_ADMIN_UPDATE_EXISTING=true also updates an existing matching admin
# (email/username/password/enabled/role); when false an existing admin is left
# untouched. Never commit real credentials.
INITIAL_ADMIN_ENABLED=false
INITIAL_ADMIN_UPDATE_EXISTING=false
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=CHANGE_ME
